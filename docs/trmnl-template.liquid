<div class="view view--full">
  <div class="layout">
    <div class="columns">
      <div class="column">
        <div class="markdown">

          <div class="title_bar">
            <img class="image image--logo" src="https://usetrmnl.com/images/plugins/trmnl--render.svg" />
            <span class="title_bar__title">Zenborg</span>
          </div>

          {% if phase %}
            <p class="label" style="margin-top: 0.5em;">
              {{ phase.emoji }} {{ phase.label }} · {{ date_label }}
              {% if cycle_name != "" %} · {{ cycle_name }}{% endif %}
            </p>

            {% if phase.moment_count > 0 %}
              {% for moment in phase.moments %}
                <p class="title" style="margin-top: 1.5em; text-align: center; font-size: 48px;">
                  {{ moment.emoji }} {{ moment.name }}
                </p>
              {% endfor %}
            {% else %}
              <p class="title" style="margin-top: 3em; text-align: center;">
                No moments yet
              </p>
            {% endif %}
          {% else %}
            <p class="label" style="margin-top: 0.5em;">
              {{ date_label }}
              {% if cycle_name != "" %} · {{ cycle_name }}{% endif %}
            </p>
            <p class="title" style="margin-top: 3em; text-align: center;">
              Between phases
            </p>
            <p class="description" style="text-align: center;">
              Rest well
            </p>
          {% endif %}

        </div>
      </div>
    </div>
  </div>
</div>
